# Datapace Agent Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Datapace API key
# Get this from https://app.datapace.ai/settings/api-keys
DATAPACE_API_KEY=your_api_key_here

# Required: HMAC-SHA256 secret used to sign every payload sent to Datapace
# Cloud. Provisioned alongside the API key and shown ONCE in the Datapace
# dashboard at connection-creation time. Distinct from DATAPACE_API_KEY by
# design — see the "Payload signing" section of the README. If you don't
# have it stored, rotate the connection in the dashboard to get a new pair.
DATAPACE_SIGNING_SECRET=your_signing_secret_here

# Required: Database connection URL
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Optional: Collection interval (default: 60s)
# Examples: 30s, 1m, 5m
COLLECTION_INTERVAL=60s

# Optional: Log level (default: info)
# Options: trace, debug, info, warn, error
LOG_LEVEL=info

# Optional: Log format (default: json)
# Options: json, pretty
LOG_FORMAT=json

# Optional: Datapace API endpoint (default: https://api.datapace.ai/v1/ingest)
# Only change this if you're using a self-hosted Datapace instance
# DATAPACE_ENDPOINT=https://api.datapace.ai/v1/ingest

# Optional: Health server bind address (default: 127.0.0.1)
# Set to 0.0.0.0 inside containers if you want to publish the health port.
# DATAPACE_HEALTH_BIND_ADDRESS=127.0.0.1

# Optional: Health server port (default: 8080)
# DATAPACE_HEALTH_PORT=8080
